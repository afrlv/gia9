# Учётные данные для входа на rcoi02.ru/gia9_result
GIA_FAMILY=Иванов
GIA_NAME=Ивано
GIA_FATHER=Иванович
GIA_PASSPORT=123456
GIA_REGION="Республика Башкортостан"

# Интервал проверки в секундах (по умолчанию 300 = 5 минут)
CHECK_INTERVAL_SECONDS=300

# Круглосуточный режим: QUIET_HOURS_ENABLED=false
# Или задайте паузу, например с 23:00 до 8:00:
QUIET_HOURS_ENABLED=false
# QUIET_HOURS_START=23:00
# QUIET_HOURS_END=8:00
TZ=Asia/Yekaterinburg

# При первом запуске сохранить текущие результаты без уведомлений
SEED_STATE=true

# iMessage (macOS): relay запускается на хосте, бот в Docker стучится сюда
IMESSAGE_ENABLED=true
IMESSAGE_TO=+79001234567,+79007654321
IMESSAGE_RELAY_URL=http://host.docker.internal:8765
IMESSAGE_RELAY_PORT=8765
# IMESSAGE_RELAY_TOKEN=случайная_строка

# Опционально: уведомления в Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
